# Copy to .env.local for local development.
# Also set these in Netlify: Site settings -> Environment variables.

# Supabase (safe to expose — protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ---- Server-only (never NEXT_PUBLIC_, never in the browser) ----
# Required once the live backend / API routes are enabled:
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYNOW_INTEGRATION_ID=
# PAYNOW_INTEGRATION_KEY=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# RESEND_API_KEY=
